{
  "$schema": "https://claude.ai/schema/settings.json",

  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  },


  "model": "sonnet",

  "env": {
    "CLAUDE_CODE_SUBAGENT_MODEL": "haiku"
  },

  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git merge:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh workflow run:*)",
      "Bash(gh pr view:*)",
      "Bash(gh issue view:*)",
      "Bash(gcloud logging read:*)",
      "Bash(gcloud run services list:*)",
      "Bash(gcloud run services describe:*)",
      "Bash(gcloud compute ssl-certificates describe:*)",
      "Bash(gcloud compute security-policies describe:*)",
      "Bash(curl -I:*)",
      "Bash(curl -s:*)",
      "Bash(node --version:*)",
      "Bash(npm run dev:*)",
      "Bash(npm run build:*)",
      "Bash(npm run test:*)",
      "Bash(npm run develop:*)",
      "Bash(npm show:*)",
      "Bash(dig:*)",
      "Bash(python3:*)",
      "Bash(gsutil ls:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)"
    ]
  }
}
